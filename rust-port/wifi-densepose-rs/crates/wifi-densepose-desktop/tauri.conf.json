{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Wave Desktop",
  "version": "0.4.4",
  "identifier": "net.ruv.wave",
  "build": {
    "frontendDist": "ui-v2/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "ui-v2"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "ui-v2"
    }
  },
  "app": {
    "windows": [
      {
        "title": "Wave Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
